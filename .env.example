# Public Supabase project values. These are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Keep server-only secrets out of NEXT_PUBLIC_* variables.
# SUPABASE_SERVICE_ROLE_KEY is intentionally not required in Phase 2.

# Optional Phase 8 Writing feedback. Leave all three unset for the safe
# no-provider fallback. Never prefix these with NEXT_PUBLIC_. The signing
# secret must match the Supabase Vault secret named writing_feedback_signing_secret.
OPENAI_API_KEY=
OPENAI_WRITING_MODEL=gpt-5-mini
WRITING_FEEDBACK_SIGNING_SECRET=

# Optional Phase 9 Speaking transcription and AI practice feedback. Leave the
# provider variables unset for the safe no-transcript/no-feedback fallback.
# SPEAKING_PIPELINE_SIGNING_SECRET must be at least 32 characters and match the
# Supabase Vault secret named speaking_pipeline_signing_secret. These values
# are server-only and must never use the NEXT_PUBLIC_ prefix.
OPENAI_SPEAKING_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SPEAKING_FEEDBACK_MODEL=gpt-5-mini
SPEAKING_PIPELINE_SIGNING_SECRET=

# Optional account for authenticated Playwright tests. Never commit real values.
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=

# Optional fresh, verified account for the one-time onboarding E2E flow.
# The test skips if this account has already completed onboarding.
E2E_ONBOARDING_EMAIL=
E2E_ONBOARDING_PASSWORD=

# Optional dedicated account for persisted learning-progress E2E.
E2E_LEARNING_EMAIL=
E2E_LEARNING_PASSWORD=

# Optional two completed-onboarding accounts for Phase 5 practice ownership E2E.
E2E_PRACTICE_USER_A_EMAIL=
E2E_PRACTICE_USER_A_PASSWORD=
E2E_PRACTICE_USER_B_EMAIL=
E2E_PRACTICE_USER_B_PASSWORD=

# Required before any authenticated E2E mutation. Use "local" for local Supabase.
E2E_EXPECTED_SUPABASE_PROJECT_REF=
